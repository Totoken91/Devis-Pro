# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email
RESEND_API_KEY=re_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Axeptio (consentement cookies RGPD) ───────────────────────────────────────
NEXT_PUBLIC_AXEPTIO_CLIENT_ID=your-axeptio-client-id
# Nom de la version de cookies configurée dans le dashboard Axeptio
NEXT_PUBLIC_AXEPTIO_COOKIES_VERSION=deviso-fr

# ── Meta Pixel ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=2574873622968634

# ── Phase 2 : Stripe ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...   # plan Pro mensuel
STRIPE_PRO_YEARLY_PRICE_ID=price_...    # plan Pro annuel (−20%)

# ── Phase 2 : Cron Vercel (relances automatiques) ─────────────────────────────
CRON_SECRET=generate-a-strong-random-string-here
